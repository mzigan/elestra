{
  "name": "elestra",
  "version": "0.1.2",
  "description": "Fine-grained reactive UI framework. No VDOM. No JSX. Pure TypeScript.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "framework",
    "reactivity",
    "signals",
    "fine-grained",
    "typescript",
    "dom",
    "ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mzigan/elestra.git"
  },
  "homepage": "https://github.com/mzigan/elestra",
  "bugs": {
    "url": "https://github.com/mzigan/elestra/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/mzigan"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.5.0"
  }
}
