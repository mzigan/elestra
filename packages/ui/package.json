{
  "name": "@elestra/ui",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/theme.css": "./dist/styles/theme.css",
    "./styles/*": "./dist/styles/*"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && npm run copy:styles",
    "copy:styles": "cp -r src/styles dist/ 2>/dev/null || true",
    "dev": "tsup --watch"
  },
  "dependencies": {},
  "peerDependencies": {
    "elestra": ">=0.0.1",
    "@elestra/primitives": ">=0.0.1"
  },
  "devDependencies": {
    "elestra": "workspace:*",
    "@elestra/primitives": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
